.container.mx-auto.px-4.py-8
  .flex.justify-between.items-center.mb-6
    %h1.text-2xl.font-bold.text-gray-900 Reports

    = link_to new_report_config_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do
      %svg.-ml-1.mr-2.h-5.w-5{viewBox: "0 0 20 20", fill: "currentColor"}
        %path{fill_rule: "evenodd", d: "M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z", clip_rule: "evenodd"}
      New Report

  .bg-white.shadow.overflow-hidden.sm:rounded-md
    %ul.divide-y.divide-gray-200
      - @report_configs.each do |config|
        %li
          .px-4.py-4.sm:px-6
            .flex.items-center.justify-between
              .flex.items-center
                %h3.text-lg.font-medium.text-blue-600.truncate
                  = link_to config.name, report_config_path(config), class: "text-blue-600 hover:text-blue-700"
                - if config.published?
                  %span.ml-2.inline-flex.items-center.px-2.5.py-0.5.rounded-full.text-xs.font-medium.bg-green-100.text-green-800
                    Published
                  %span.ml-2.text-sm.text-gray-500
                    Last published: #{config.last_published_at}
                - else
                  %span.ml-2.inline-flex.items-center.px-2.5.py-0.5.rounded-full.text-xs.font-medium.bg-yellow-100.text-yellow-800
                    Draft
              .ml-2.flex-shrink-0.flex
                = link_to history_report_config_path(config), class: "text-gray-600 hover:text-gray-900", title: "View History" do
                  %svg.h-5.w-5{viewBox: "0 0 20 20", fill: "currentColor"}
                    %path{fill_rule: "evenodd", d: "M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z", clip_rule: "evenodd"}
                = link_to edit_report_config_path(config), class: "ml-3 text-blue-600 hover:text-blue-900" do
                  %svg.h-5.w-5{viewBox: "0 0 20 20", fill: "currentColor"}
                    %path{d: "M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"}
                = button_to report_config_path(config), method: :delete, class: "ml-3 text-red-600 hover:text-red-900", data: { confirm: "Are you sure?" } do
                  %svg.h-5.w-5{viewBox: "0 0 20 20", fill: "currentColor"}
                    %path{fill_rule: "evenodd", d: "M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z", clip_rule: "evenodd"}
            .mt-2.sm:flex.sm:justify-between
              .sm:flex
                %p.flex.items-center.text-sm.text-gray-500
                  %svg.flex-shrink-0.mr-1.5.h-5.w-5.text-gray-400{viewBox: "0 0 20 20", fill: "currentColor"}
                    %path{fill_rule: "evenodd", d: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z", clip_rule: "evenodd"}
                  = config.frequency.titleize
                %p.mt-2.flex.items-center.text-sm.text-gray-500.sm:mt-0.sm:ml-6
                  %svg.flex-shrink-0.mr-1.5.h-5.w-5.text-gray-400{viewBox: "0 0 20 20", fill: "currentColor"}
                    %path{fill_rule: "evenodd", d: "M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z", clip_rule: "evenodd"}
                  = config.recipients
              .mt-2.flex.items-center.text-sm.text-gray-500.sm:mt-0
                %svg.flex-shrink-0.mr-1.5.h-5.w-5.text-gray-400{viewBox: "0 0 20 20", fill: "currentColor"}
                  %path{fill_rule: "evenodd", d: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z", clip_rule: "evenodd"}
                = config.model.titleize 