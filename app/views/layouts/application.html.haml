!!!
%html
  %head
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title botmo
    %meta{:name => "viewport", :content => "width=device-width,initial-scale=1"}
    %meta{:content => "yes", :name => "apple-mobile-web-app-capable"}/
    %meta{:content => "yes", :name => "mobile-web-app-capable"}/
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    %link{:href => "/icon.png", :rel => "icon", :type => "image/png"}/
    %link{:href => "/icon.svg", :rel => "icon", :type => "image/svg+xml"}/
    %link{:href => "/icon.png", :rel => "apple-touch-icon"}/

    :css
      | .logo {
          font-weight: 900;
          font-family: 'Roboto', sans-serif;
        }

    = stylesheet_link_tag "tailwind", "data-turbo-track": "reload"
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = javascript_importmap_tags

  %body.bg-gray-50
    .bg-gray.shadow-sm
      .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
        .flex.justify-between.h-16.items-center
          = link_to root_path, class: "flex items-center" do
            -# %span.text-2xl.font-['Roboto'].text-blue-600 botmo
            %span.text-2xl.text-blue-900.logo
              %b
                botmo
          
          .flex.items-center.space-x-4
            - if user_signed_in?
              = link_to "New Report", new_report_config_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium"
              .flex.items-center.space-x-4
                %span.text-gray-700
                  = link_to current_user.name, report_configs_path, class: "text-blue-600 hover:text-blue-700 text-sm font-medium"
                = link_to "Logout", "/auth/logout", class: "text-red-600 hover:text-red-700 text-sm font-medium"
            - else
              = link_to "Login", "/auth/login", class: "text-blue-600 hover:text-blue-700 text-sm font-medium"

    .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8.py-8
      - if notice
        .bg-green-100.border.border-green-400.text-green-700.px-4.py-3.rounded.relative.mb-4{role: "alert"}
          %span.block.sm:inline= notice
      - if alert
        .bg-red-100.border.border-red-400.text-red-700.px-4.py-3.rounded.relative.mb-4{role: "alert"}
          %span.block.sm:inline= alert
      = yield
