.container.mx-auto.px-4.py-8
  .max-w-2xl.mx-auto.text-center

    -# current_user: #{current_user.inspect}

    - if user_signed_in?
      - if current_user.report_configs.any?
        %h1.text-4xl.font-bold.mb-6 Welcome back!
        %p.text-xl.mb-8 Manage your automated reports or create a new one.
        = link_to "Create New Report", new_report_config_path, class: "inline-block bg-blue-600 text-white py-3 px-6 rounded-lg hover:bg-blue-700 transition-colors"
      - else
        %h1.text-4xl.font-bold.mb-6 Welcome to botmo!
        %p.text-xl.mb-8 Get started by creating your first report.
        = link_to "Create Your First Report", new_report_config_path, class: "inline-block bg-blue-600 text-white py-3 px-6 rounded-lg hover:bg-blue-700 transition-colors"
        
    - else
      %h1.text-4xl.font-bold.mb-6 Welcome to botmo!
      %p.text-xl.mb-8 Please create an account or log in to get started.
      .space-y-4
        = link_to "Log In", "/auth/login", class: "block w-full bg-blue-600 text-white py-3 px-6 rounded-lg hover:bg-blue-700 transition-colors"
        = link_to "Sign Up", "/auth/login", class: "block w-full bg-white text-blue-600 border-2 border-blue-600 py-3 px-6 rounded-lg hover:bg-blue-50 transition-colors" 