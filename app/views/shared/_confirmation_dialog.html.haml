.fixed.inset-0.bg-gray-500.bg-opacity-75.transition-opacity{"data-confirmation-target" => "dialog"}
  .fixed.inset-0.z-10.overflow-y-auto
    .flex.min-h-full.items-end.justify-center.p-4.text-center.sm:items-center.sm:p-0
      .relative.transform.overflow-hidden.rounded-lg.bg-white.px-4.pb-4.pt-5.text-left.shadow-xl.transition-all.sm:my-8.sm:w-full.sm:max-w-lg.sm:p-6
        .sm:flex.sm:items-start
          .mx-auto.flex.h-12.w-12.flex-shrink-0.items-center.justify-center.rounded-full.bg-red-100.sm:mx-0.sm:h-10.sm:w-10
            %svg.h-6.w-6.text-red-600{viewBox: "0 0 20 20", fill: "currentColor"}
              %path{fill_rule: "evenodd", d: "M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z", clip_rule: "evenodd"}
          .mt-3.text-center.sm:ml-4.sm:mt-0.sm:text-left
            %h3.text-base.font-semibold.leading-6.text-gray-900
              = title
            .mt-2
              %p.text-sm.text-gray-500
                = message
        .mt-5.sm:mt-4.sm:flex.sm:flex-row-reverse
          = button_to action, method: :post, class: "inline-flex w-full justify-center rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 sm:ml-3 sm:w-auto", data: { confirmation_target: "confirmButton" } do
            Confirm
          = button_tag "Cancel", type: "button", class: "mt-3 inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:mt-0 sm:w-auto", data: { action: "click->confirmation#cancel", confirmation_target: "cancelButton" } 